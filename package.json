{
  "name": "@jaesong/agent-task-manager",
  "version": "0.2.0",
  "description": "Self-hosted task manager for teams already using OpenClaw as their Slack bot.",
  "private": false,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/json-choi/agent-task-manager.git"
  },
  "homepage": "https://github.com/json-choi/agent-task-manager#readme",
  "bugs": {
    "url": "https://github.com/json-choi/agent-task-manager/issues"
  },
  "keywords": [
    "agent",
    "slack",
    "task-manager",
    "self-hosted",
    "openclaw",
    "elysia",
    "bun"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "atm": "bin/task-manager.js",
    "agent-task-manager": "bin/task-manager.js"
  },
  "files": [
    "agent-plugin/",
    "assets/brand/atm-mark.svg",
    "assets/brand/atm-persona.svg",
    "bin/",
    "CHANGELOG.md",
    "docs/",
    "LICENSE",
    "public/",
    "src/",
    ".env.example",
    "README.md",
    "bun.lock",
    "install.sh",
    "package.json",
    "tsconfig.json"
  ],
  "scripts": {
    "build": "bun run build:client",
    "build:client": "bun build src/client/dashboard.tsx --outfile public/src/main.js",
    "dev": "bun run build:client && bun --watch src/server/index.ts",
    "start": "bun run build:client && bun src/server/index.ts",
    "worker": "bun src/worker/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "cli:check": "node --check bin/task-manager.js",
    "prepack": "bun run build:client"
  },
  "dependencies": {
    "@elysiajs/static": "latest",
    "better-auth": "^1.6.9",
    "elysia": "latest",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "latest"
  }
}
