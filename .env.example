DATA_DIR=./data
PORT=3011
PUBLIC_BASE_URL=http://localhost:3011
BETTER_AUTH_SECRET=replace-with-a-random-secret-at-least-32-characters
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# Optional unattended first-run bootstrap.
TASK_MANAGER_BOOTSTRAP=false
TASK_MANAGER_BOOTSTRAP_STRICT=false
TASK_MANAGER_ADMIN_EMAIL=admin@example.com
TASK_MANAGER_ADMIN_PASSWORD=change-this-password
TASK_MANAGER_OPENCLAW_WORKSPACE=
TASK_MANAGER_OPENCLAW_CLI=openclaw
TASK_MANAGER_OPENCLAW_RUN_RELOAD=true
TASK_MANAGER_OPENCLAW_FORCE_INSTALL=false
TASK_MANAGER_OPENCLAW_REGENERATE_TOKEN=true
TASK_MANAGER_SLACK_PERMISSIONS_REVIEWED=false
TASK_MANAGER_PUBLIC_ACCESS_MODE=quick
TASK_MANAGER_PUBLIC_URL=
TASK_MANAGER_LOCAL_SERVICE_URL=http://localhost:3011
TASK_MANAGER_CLOUDFLARE_TUNNEL_NAME=
TASK_MANAGER_CLOUDFLARE_TUNNEL_TOKEN=
TASK_MANAGER_PUBLIC_ACCESS_PROTECTED=false
